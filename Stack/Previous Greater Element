class Solution {
  public:
    vector<int> preGreaterEle(vector<int>& arr) {
        vector<int> res;
        stack<int> st;
        st.push(arr[0]);
        res.push_back(-1);
        for(int i=1;i<arr.size();i++){
            while(!st.empty() && st.top()<=arr[i]) st.pop();
            if(st.empty()) res.push_back(-1);
            else res.push_back(st.top());
            st.push(arr[i]);
        }
        return res;
    }
};
